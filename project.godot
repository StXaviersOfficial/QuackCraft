; Engine configuration file.
; QuackCraft — original voxel sandbox for Android
; Engine: Godot 4.3-stable

config_version=5

[application]

config/name="QuackCraft"
config/description="An original voxel building & survival sandbox for Android."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("PackScriptLanguageFeatures", "PackedScene")
config/icon="res://icon.svg"
config/version="0.1.0"

[autoload]

BlockRegistry="*res://scripts/blocks/BlockRegistry.gd"
ItemRegistry="*res://scripts/items/ItemRegistry.gd"
WorldRef="*res://scripts/autoload/WorldRef.gd"
AudioMgr="*res://scripts/autoload/AudioMgr.gd"
Settings="*res://scripts/autoload/Settings.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/handheld/orientation=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale=1.0

[input]

# Touch / mobile controls are handled in MobileControls.gd via InputEventScreenTouch / ScreenDrag
# These input actions are used for testing on desktop and for action mapping.

